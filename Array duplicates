class Solution:
    def findDuplicates(self, arr):
        count = {}
        result = []
        
        for num in arr:
            if num in count:
                count[num] += 1
            else:
                count[num] = 1
        
        for key in count:
            if count[key] == 2:
                result.append(key)
        
        return result
