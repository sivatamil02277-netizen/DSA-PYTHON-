class Solution:
    def binarysearch(self, arr, k):
        left = 0
        right = len(arr) - 1
        result = -1
        
        while left <= right:
            mid = (left + right) // 2
            
            if arr[mid] == k:
                result = mid
                right = mid - 1   # continue searching left part
            elif arr[mid] < k:
                left = mid + 1
            else:
                right = mid - 1
                
        return result
        
