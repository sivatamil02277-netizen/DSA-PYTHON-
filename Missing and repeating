class Solution:
    def findTwoElement(self, arr):
        n = len(arr)
        count = [0] * (n + 1)
        
        for num in arr:
            count[num] += 1
        
        duplicate = -1
        missing = -1
        
        for i in range(1, n + 1):
            if count[i] == 2:
                duplicate = i
            elif count[i] == 0:
                missing = i
        
        return [duplicate, missing]

